# ==========================================
# 1. DJANGO & MIGRACIONES (MODO COLABORATIVO)
# ==========================================
# Ignora todas las migraciones generadas localmente para evitar choques
**/migrations/*.py

# EXCEPCIÓN: No ignorar los __init__.py (necesarios para que Django vea la carpeta)
!**/migrations/__init__.py

# Ignora el caché de las migraciones
**/migrations/__pycache__/

# Archivos de configuración local y secretos
local_settings.py
.env
*.env

# Archivos de Medios y Estáticos (Subidas de usuarios y archivos generados)
media/
static/
staticfiles/
/site

# ==========================================
# 2. BASES DE DATOS (NO COMPARTIDAS)
# ==========================================
*.sqlite3
*.sqlite3-journal
*.db
*.db-journal
*.rdb
*.aof

# ==========================================
# 3. ENTORNOS VIRTUALES Y PAQUETES
# ==========================================
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
bin/
lib/
lib64/
include/
share/python-wheels/
__pypackages__/
.pixi/

