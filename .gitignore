*.xlsx
*.xls
*.csv
*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.ods

# ==========================================
# 5. PYTHON: COMPILADOS Y CACHÉ
# ==========================================
__pycache__/
*.py[codz]
*$py.class
*.so
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

